<?xml version="1.0" encoding="utf-8"?>
<!-- Play button: 100x100, radius 32dp, gradient glow bg matching HTML .play -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer blue glow -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000"/>
            <corners android:radius="36dp"/>
            <stroke android:width="10dp" android:color="#3300C3FF"/>
        </shape>
    </item>
    <!-- Outer purple glow -->
    <item android:top="4dp" android:left="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000"/>
            <corners android:radius="34dp"/>
            <stroke android:width="6dp" android:color="#22FF00EA"/>
        </shape>
    </item>
    <!-- Button body: gradient bg -->
    <item android:top="10dp" android:left="10dp" android:right="10dp" android:bottom="10dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="145"
                android:startColor="#2200C3FF"
                android:endColor="#22FF00EA"/>
            <corners android:radius="32dp"/>
            <stroke android:width="1dp" android:color="#22FFFFFF"/>
        </shape>
    </item>
</layer-list>
