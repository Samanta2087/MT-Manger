<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F0F2F8" />
        </shape>
    </item>
    <item android:top="4dp" android:left="12dp" android:right="12dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#0A000040" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item android:top="2dp" android:left="10dp" android:right="10dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#F0F4FF"
                android:endColor="#EAF0FF" />
            <corners android:radius="18dp" />
            <stroke android:width="1dp" android:color="#60FFFFFF" />
        </shape>
    </item>
    <item android:top="4dp" android:left="14dp" android:right="14dp" android:bottom="32dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#40FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners
                android:topLeftRadius="16dp"
                android:topRightRadius="16dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
        </shape>
    </item>
</layer-list>
