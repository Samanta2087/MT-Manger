<?xml version="1.0" encoding="utf-8"?>
<!-- Floating header bar – acrylic frosted glass -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E8F0F4FF" />
            <stroke android:width="1dp" android:color="#50FFFFFF" />
        </shape>
    </item>
    <!-- Bottom separator shimmer -->
    <item android:top="52dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#004A7CF7"
                android:centerColor="#664A7CF7"
                android:endColor="#004A7CF7" />
        </shape>
    </item>
</layer-list>
