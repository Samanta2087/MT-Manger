<?xml version="1.0" encoding="utf-8"?>
<!-- Floating glass icon button (header) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow -->
    <item android:top="2dp" android:left="1dp" android:right="1dp" android:bottom="-1dp">
        <shape android:shape="oval">
            <solid android:color="#18000040" />
        </shape>
    </item>
    <!-- Frosted glass circle -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#D0FFFFFF" />
            <stroke android:width="1dp" android:color="#60FFFFFF" />
        </shape>
    </item>
    <!-- Top specular – fixed 16dp instead of 50% -->
    <item android:bottom="16dp">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#50FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
