<?xml version="1.0" encoding="utf-8"?>
<!-- Notification badge — red gradient circle with shadow -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="1dp" android:left="1dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="oval">
            <solid android:color="#40EF4444" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:startColor="#EF4444"
                android:endColor="#F87171"
                android:angle="135" />
            <stroke android:width="1dp" android:color="#30FFFFFF" />
        </shape>
    </item>
</layer-list>
