<?xml version="1.0" encoding="utf-8"?>
<!-- Enhanced 3D neumorphic pill button with stronger extrusion & realistic lighting -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer ambient shadow (spread) -->
    <item
        android:top="5dp"
        android:left="3dp"
        android:right="3dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#20A855F7" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Bottom depth edge (hard extrusion) -->
    <item
        android:top="4dp"
        android:left="2dp"
        android:right="2dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#30C4B5D6" />
            <corners android:radius="15dp" />
        </shape>
    </item>

    <!-- Main pill surface: white-to-soft gradient -->
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#FEFFFFFF"
                android:endColor="#FAEEF3FF"
                android:angle="270" />
            <corners android:radius="14dp" />
            <stroke
                android:width="1dp"
                android:color="#D0FFFFFF" />
        </shape>
    </item>

    <!-- Top-left specular highlight (corner catch) -->
    <item
        android:bottom="28dp"
        android:left="3dp"
        android:right="12dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#70FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <corners
                android:topLeftRadius="14dp"
                android:topRightRadius="0dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
        </shape>
    </item>

    <!-- Right edge gloss highlight -->
    <item
        android:bottom="18dp"
        android:left="36dp"
        android:right="3dp"
        android:top="6dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#00FFFFFF"
                android:endColor="#35FFFFFF"
                android:angle="0" />
            <corners
                android:topLeftRadius="0dp"
                android:topRightRadius="14dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
        </shape>
    </item>

</layer-list>
