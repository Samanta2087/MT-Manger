<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer soft glow shadow -->
    <item android:top="3dp" android:left="3dp" android:right="-3dp" android:bottom="-3dp">
        <shape android:shape="rectangle">
            <solid android:color="#14000050" />
            <corners android:radius="30dp" />
        </shape>
    </item>
    <!-- Translucent frosted glass -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F8F9FF" />
            <corners android:radius="28dp" />
            <stroke android:width="1dp" android:color="#25FFFFFF" />
        </shape>
    </item>
    <!-- Top gloss -->
    <item android:bottom="40dp">
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="270"
                android:startColor="#70FFFFFF" android:endColor="#00FFFFFF" />
            <corners android:topLeftRadius="28dp" android:topRightRadius="28dp"
                android:bottomLeftRadius="0dp" android:bottomRightRadius="0dp" />
        </shape>
    </item>
</layer-list>
