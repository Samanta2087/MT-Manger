<?xml version="1.0" encoding="utf-8"?>
<!-- 3D Sphere Add Button — purple-to-blue gradient with glossy highlight and rim light -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Deep outer shadow -->
    <item android:top="6dp" android:left="6dp" android:right="6dp" android:bottom="2dp">
        <shape android:shape="oval">
            <solid android:color="#30A78BFA" />
        </shape>
    </item>

    <!-- Mid shadow layer -->
    <item android:top="4dp" android:left="4dp" android:right="4dp" android:bottom="1dp">
        <shape android:shape="oval">
            <solid android:color="#2560A5FA" />
        </shape>
    </item>

    <!-- Main sphere gradient: purple (#a78bfa) → blue (#60a5fa) -->
    <item android:bottom="1dp">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:startColor="#A78BFA"
                android:centerColor="#8B9DFA"
                android:endColor="#60A5FA"
                android:angle="135" />
            <stroke
                android:width="1dp"
                android:color="#90E0E7FF" />
        </shape>
    </item>

    <!-- Glossy highlight overlay (::before equivalent) — top oval shine -->
    <item
        android:top="6dp"
        android:left="12dp"
        android:right="16dp"
        android:bottom="36dp">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:startColor="#90FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
        </shape>
    </item>

    <!-- Secondary soft highlight — upper-left catchlight -->
    <item
        android:top="8dp"
        android:left="16dp"
        android:right="32dp"
        android:bottom="40dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:startColor="#70FFFFFF"
                android:endColor="#00FFFFFF"
                android:gradientRadius="14dp" />
        </shape>
    </item>

    <!-- Bottom-right blue-tinted reflection -->
    <item
        android:top="38dp"
        android:left="28dp"
        android:right="10dp"
        android:bottom="8dp">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:startColor="#00FFFFFF"
                android:endColor="#35FFFFFF"
                android:angle="270" />
        </shape>
    </item>

    <!-- Subtle rim light ring -->
    <item
        android:top="-1dp"
        android:left="-1dp"
        android:right="-1dp"
        android:bottom="-1dp">
        <shape android:shape="oval">
                <stroke
                    android:width="1.5dp"
                    android:color="#40FFFFFF" />
        </shape>
    </item>

</layer-list>
