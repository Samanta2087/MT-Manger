<?xml version="1.0" encoding="utf-8"?>
<!-- Quick access category pill button – floating 3D glass -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow -->
    <item android:top="2dp" android:left="1dp" android:right="1dp" android:bottom="-2dp">
        <shape android:shape="rectangle">
            <solid android:color="#124A7CF7" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Frosted pill -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E0FFFFFF" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#55FFFFFF" />
        </shape>
    </item>
    <!-- Gloss top – fixed 18dp instead of 50% -->
    <item android:bottom="18dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#45FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners
                android:topLeftRadius="14dp"
                android:topRightRadius="14dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
        </shape>
    </item>
</layer-list>
