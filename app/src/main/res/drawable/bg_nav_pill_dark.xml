<?xml version="1.0" encoding="utf-8"?>
<!-- Dark theme nav pill button — elevated dark surface with subtle glow -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom shadow -->
    <item android:top="3dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#223B82F6" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <!-- Main dark surface -->
    <item android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#1E2A3A"
                android:endColor="#161D29"
                android:angle="270" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#1AFFFFFF" />
        </shape>
    </item>
</layer-list>
