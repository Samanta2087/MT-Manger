<?xml version="1.0" encoding="utf-8"?>
<!-- Floating top-bar pill container – soft neumorphic light pill matching the design -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer soft shadow -->
    <item
        android:top="3dp"
        android:left="3dp"
        android:right="3dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#14000000" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- Main pill surface -->
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#F1F3F9" />
            <corners android:radius="24dp" />
            <stroke android:width="1dp" android:color="#E2E6F0" />
        </shape>
    </item>
    <!-- Top highlight for glass feel -->
    <item
        android:top="2dp"
        android:left="4dp"
        android:right="4dp"
        android:bottom="40dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#50FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <corners android:topLeftRadius="24dp" android:topRightRadius="24dp" />
        </shape>
    </item>
</layer-list>
