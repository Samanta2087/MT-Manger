<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="56dp"
                android:startColor="#554F8EF7"
                android:endColor="#0022D3EE" />
        </shape>
    </item>
    <!-- Mid glow ring -->
    <item android:top="6dp" android:left="6dp" android:right="6dp" android:bottom="6dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="#4F8EF7"
                android:endColor="#6BA3FF"
                android:type="linear"
                android:angle="135" />
        </shape>
    </item>
</layer-list>
