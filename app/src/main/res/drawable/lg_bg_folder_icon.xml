<?xml version="1.0" encoding="utf-8"?>
<!-- 3D glass folder icon container – soft blue with gloss -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Drop shadow -->
    <item android:top="3dp" android:left="2dp" android:right="2dp" android:bottom="-2dp">
        <shape android:shape="rectangle">
            <solid android:color="#1A4A7CF7" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- Main body: blue gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#6B9EFF"
                android:endColor="#4A7CF7" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <!-- Gloss overlay top-half – fixed 18dp instead of 50% -->
    <item android:bottom="20dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#50FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners
                android:topLeftRadius="10dp"
                android:topRightRadius="10dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
        </shape>
    </item>
</layer-list>
