<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="8dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:background="@drawable/bg_neu_card"
    android:layout_marginBottom="8dp">

    <!-- Neumorphic icon container -->
    <FrameLayout
        android:id="@+id/iconContainer"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:background="@drawable/bg_menu_icon">

        <ImageView
            android:id="@+id/ivActionIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:scaleType="fitCenter" />
    </FrameLayout>

    <!-- Title + Subtitle -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="14dp">

        <TextView
            android:id="@+id/tvActionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/lg_text_primary"
            android:textSize="14.5sp"
            android:textFontWeight="500"
            android:maxLines="1"
            android:ellipsize="end"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/tvActionSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/lg_text_muted"
            android:textSize="11.5sp"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:includeFontPadding="false" />
    </LinearLayout>

    <!-- Chevron arrow -->
    <ImageView
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_arrow_right"
        android:tint="@color/lg_text_muted"
        android:alpha="0.5"
        android:layout_marginStart="8dp" />
</LinearLayout>