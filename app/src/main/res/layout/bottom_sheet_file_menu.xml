<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_sheet_surface"
    android:orientation="vertical">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        android:background="@color/text_muted"
        android:alpha="0.4"
        android:backgroundTint="@null" />

    <!-- File Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- File Icon -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_menu_icon">
            <ImageView
                android:id="@+id/ivMenuFileIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_file_flat" />
        </FrameLayout>

        <!-- Name + meta -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp">
            <TextView
                android:id="@+id/tvMenuFileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="middle" />
            <TextView
                android:id="@+id/tvMenuFileMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_default"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp" />

    <!-- ── Actions ── -->

    <!-- Open -->
    <LinearLayout
        android:id="@+id/menuOpen"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="?attr/selectableItemBackground">
        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
            android:background="@drawable/bg_menu_icon">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_folder_flat"
                android:id="@+id/ivMenuOpenIcon" />
        </FrameLayout>
        <TextView android:id="@+id/tvMenuOpenLabel"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="16dp"
            android:text="Open" android:textColor="@color/text_primary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Edit (text files only) -->
    <LinearLayout
        android:id="@+id/menuEdit"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:visibility="gone"
        android:background="?attr/selectableItemBackground">
        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
            android:background="@drawable/bg_menu_icon">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_edit"
                android:tint="#34D399" />
        </FrameLayout>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="16dp"
            android:text="Edit" android:textColor="@color/text_primary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Rename -->
    <LinearLayout
        android:id="@+id/menuRename"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="?attr/selectableItemBackground">
        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
            android:background="@drawable/bg_menu_icon">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_edit"
                android:tint="#FB923C" />
        </FrameLayout>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="16dp"
            android:text="Rename" android:textColor="@color/text_primary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Copy -->
    <LinearLayout
        android:id="@+id/menuCopy"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="?attr/selectableItemBackground">
        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
            android:background="@drawable/bg_menu_icon">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_copy"
                android:tint="#4F8EF7" />
        </FrameLayout>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="16dp"
            android:text="Copy" android:textColor="@color/text_primary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Cut -->
    <LinearLayout
        android:id="@+id/menuCut"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="?attr/selectableItemBackground">
        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
            android:background="@drawable/bg_menu_icon">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_cut"
                android:tint="#FBBF24" />
        </FrameLayout>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="16dp"
            android:text="Cut" android:textColor="@color/text_primary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Move To -->
    <LinearLayout
        android:id="@+id/menuMove"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="?attr/selectableItemBackground">
        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
            android:background="@drawable/bg_menu_icon">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_move"
                android:tint="#10B981" />
        </FrameLayout>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="16dp"
            android:text="Move To…" android:textColor="@color/text_primary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_default"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp" />

    <!-- Delete -->
    <LinearLayout
        android:id="@+id/menuDelete"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="?attr/selectableItemBackground">
        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
            android:background="@drawable/bg_menu_icon">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_delete"
                android:tint="#F87171" />
        </FrameLayout>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="16dp"
            android:text="Delete" android:textColor="#F87171"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Share -->
    <LinearLayout
        android:id="@+id/menuShare"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="?attr/selectableItemBackground">
        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
            android:background="@drawable/bg_menu_icon">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_share"
                android:tint="#A78BFA" />
        </FrameLayout>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="16dp"
            android:text="Share" android:textColor="@color/text_primary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Properties -->
    <LinearLayout
        android:id="@+id/menuProperties"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="?attr/selectableItemBackground">
        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
            android:background="@drawable/bg_menu_icon">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_info"
                android:tint="#22D3EE" />
        </FrameLayout>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="16dp"
            android:text="Properties" android:textColor="@color/text_primary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Select -->
    <LinearLayout
        android:id="@+id/menuSelect"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="?attr/selectableItemBackground">
        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
            android:background="@drawable/bg_menu_icon">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_select_all"
                android:tint="#8BA8CC" />
        </FrameLayout>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="16dp"
            android:text="Select" android:textColor="@color/text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Bottom safe area -->
    <View
        android:layout_width="match_parent"
        android:layout_height="16dp" />

</LinearLayout>
