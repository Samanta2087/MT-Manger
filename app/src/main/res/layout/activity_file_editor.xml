<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E1E">

    <!-- Editor Toolbar — always dark, 48dp -->
    <LinearLayout
        android:id="@+id/editorToolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#252526"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="#858585"
            android:scaleType="centerInside"
            android:contentDescription="Back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="4dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/tvEditorFileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#D4D4D4"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="middle"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvEditorPath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#5A5A5A"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="start" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnFind"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_search"
            android:tint="#858585"
            android:scaleType="centerInside"
            android:contentDescription="Find" />

        <ImageButton
            android:id="@+id/btnUndo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_undo"
            android:tint="#858585"
            android:scaleType="centerInside"
            android:contentDescription="Undo" />

        <ImageButton
            android:id="@+id/btnRedo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_redo"
            android:tint="#858585"
            android:scaleType="centerInside"
            android:contentDescription="Redo" />

        <ImageButton
            android:id="@+id/btnSave"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_save"
            android:tint="#569CD6"
            android:scaleType="centerInside"
            android:contentDescription="Save" />

        <ImageButton
            android:id="@+id/btnEditorMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_more_vert"
            android:tint="#858585"
            android:scaleType="centerInside"
            android:contentDescription="More options" />

    </LinearLayout>

    <!-- Toolbar bottom border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333" />

    <!-- Find/Replace Bar -->
    <LinearLayout
        android:id="@+id/findReplaceBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#252526"
        android:orientation="vertical"
        android:padding="6dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etFindText"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#1E1E1E"
                android:hint="Find..."
                android:textColorHint="#5A5A5A"
                android:textColor="#D4D4D4"
                android:textSize="12sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:inputType="text"
                android:imeOptions="actionSearch" />

            <TextView
                android:id="@+id/tvMatchCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#858585"
                android:textSize="11sp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp" />

            <ImageButton
                android:id="@+id/btnFindPrev"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_up"
                android:tint="#858585"
                android:scaleType="centerInside"
                android:contentDescription="Previous" />

            <ImageButton
                android:id="@+id/btnFindNext"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_down"
                android:tint="#858585"
                android:scaleType="centerInside"
                android:contentDescription="Next" />

            <ImageButton
                android:id="@+id/btnCloseFindReplace"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                android:tint="#858585"
                android:scaleType="centerInside"
                android:contentDescription="Close" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <EditText
                android:id="@+id/etReplaceText"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#1E1E1E"
                android:hint="Replace with..."
                android:textColorHint="#5A5A5A"
                android:textColor="#D4D4D4"
                android:textSize="12sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:inputType="text" />

            <Button
                android:id="@+id/btnReplace"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Replace"
                android:textSize="11sp"
                android:textColor="#D4D4D4"
                android:backgroundTint="#333333"
                android:minHeight="0dp"
                android:layout_marginStart="4dp" />

            <Button
                android:id="@+id/btnReplaceAll"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="All"
                android:textSize="11sp"
                android:textColor="#D4D4D4"
                android:backgroundTint="#333333"
                android:minHeight="0dp"
                android:layout_marginStart="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Editor Area -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEditor"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1E1E1E"
        android:overScrollMode="never"
        android:scrollbars="vertical"
        android:fadeScrollbars="false"
        android:clipToPadding="false" />

    <!-- Status bar top border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333" />

    <!-- Status Bar — always dark, compact 20dp -->
    <LinearLayout
        android:id="@+id/editorStatusBar"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:background="#252526"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <TextView
            android:id="@+id/tvCursorPos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ln 1, Col 1"
            android:textColor="#858585"
            android:textSize="10sp"
            android:fontFamily="monospace" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  │  "
            android:textColor="#3C3C3C"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvEncoding"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UTF-8"
            android:textColor="#858585"
            android:textSize="10sp"
            android:fontFamily="monospace" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  │  "
            android:textColor="#3C3C3C"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvFileType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#569CD6"
            android:textSize="10sp"
            android:fontFamily="monospace" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <TextView
            android:id="@+id/tvModified"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="●"
            android:textColor="#CE9178"
            android:textSize="10sp"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>