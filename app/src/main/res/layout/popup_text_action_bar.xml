<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="46dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="10dp"
    app:cardBackgroundColor="@color/bg_card"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp">

        <!-- Search in selection -->
        <ImageButton
            android:id="@+id/btnActSearch"
            android:layout_width="48dp"
            android:layout_height="42dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_search"
            android:tint="@color/text_secondary"
            android:contentDescription="Search" />

        <View
            android:layout_width="1dp"
            android:layout_height="22dp"
            android:background="@color/border_default" />

        <!-- Select All -->
        <ImageButton
            android:id="@+id/btnActSelectAll"
            android:layout_width="48dp"
            android:layout_height="42dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_select_all"
            android:tint="@color/text_secondary"
            android:contentDescription="Select All" />

        <View
            android:layout_width="1dp"
            android:layout_height="22dp"
            android:background="@color/border_default" />

        <!-- Cut -->
        <ImageButton
            android:id="@+id/btnActCut"
            android:layout_width="48dp"
            android:layout_height="42dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_cut"
            android:tint="@color/text_secondary"
            android:contentDescription="Cut" />

        <View
            android:layout_width="1dp"
            android:layout_height="22dp"
            android:background="@color/border_default" />

        <!-- Copy -->
        <ImageButton
            android:id="@+id/btnActCopy"
            android:layout_width="48dp"
            android:layout_height="42dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_copy"
            android:tint="@color/text_secondary"
            android:contentDescription="Copy" />

        <View
            android:layout_width="1dp"
            android:layout_height="22dp"
            android:background="@color/border_default" />

        <!-- Paste -->
        <ImageButton
            android:id="@+id/btnActPaste"
            android:layout_width="48dp"
            android:layout_height="42dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_paste"
            android:tint="@color/accent_blue"
            android:contentDescription="Paste" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
