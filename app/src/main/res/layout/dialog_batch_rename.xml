<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <RadioGroup
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/rbRenameAll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sequential rename"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="32dp"
            android:paddingTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Base name:"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/etSingleName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g., Photo"
                android:inputType="text"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Files will be renamed: Photo1, Photo2, etc."
                android:textSize="10sp"
                android:textColor="@color/text_muted"
                android:paddingTop="4dp" />

        </LinearLayout>

        <RadioButton
            android:id="@+id/rbUsePattern"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Find and replace"
            android:textSize="14sp"
            android:paddingTop="8dp" />

        <LinearLayout
            android:id="@+id/containerPattern"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="32dp"
            android:paddingTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Find:"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/etOldPattern"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Text to find"
                android:inputType="text"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Replace with:"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:paddingTop="8dp" />

            <EditText
                android:id="@+id/etNewPattern"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Replacement text"
                android:inputType="text"
                android:textSize="14sp" />

        </LinearLayout>

    </RadioGroup>

</LinearLayout>
