<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/xyvionBgMain">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:background="?attr/xyvionBgSearchHeader"
        android:elevation="6dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="11dp"
            android:background="?attr/xyvionBgHeaderBtn"
            android:src="@drawable/ic_arrow_back"
            android:tint="?attr/xyvionTextSecondary"
            android:contentDescription="Back"
            android:layout_marginEnd="6dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:background="?attr/xyvionBgSearchField"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="10dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                android:tint="?attr/colorPrimary"
                android:layout_marginEnd="10dp" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Search files and content..."
                android:textColorHint="?attr/xyvionTextMuted"
                android:textColor="?attr/xyvionTextPrimary"
                android:textSize="14sp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="?attr/xyvionBgBorder"
        android:alpha="0.5" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="?attr/xyvionBgElevated"
        android:scrollbars="none"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <LinearLayout
            android:id="@+id/filterChips"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvResultsHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="?attr/xyvionTextMuted"
        android:textSize="11sp"
        android:letterSpacing="0.05"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/searchResultsRv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_search"
            android:tint="?attr/xyvionTextMuted"
            android:alpha="0.4" />

        <TextView
            android:id="@+id/tvEmptyMsg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Type to search files"
            android:textColor="?attr/xyvionTextMuted"
            android:textSize="14sp"
            android:paddingTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Searches file names across storage"
            android:textColor="?attr/xyvionTextMuted"
            android:textSize="11sp"
            android:alpha="0.6"
            android:paddingTop="4dp" />

    </LinearLayout>

</LinearLayout>
