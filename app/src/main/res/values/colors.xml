        LIGHT THEME BASE COLORS
        These values are used by BOTH themes via @color/ references in layouts.
        Dark theme overrides are in values-night/colors.xml.
        The Light Glass theme (Theme.XYvion.LiquidGlass) uses these light values.
    -->

    <!-- Backgrounds (light) -->
    <color name="bg_primary">#F0F4FF</color>
    <color name="bg_surface">#F8FAFF</color>
    <color name="bg_card">#FFFFFF</color>
    <color name="bg_elevated">#EAEDFF</color>
    <color name="bg_gradient_start">#EEF2FF</color>
    <color name="bg_gradient_end">#F5F0FF</color>
    <color name="bg_card_glass">#CCFFFFFF</color>
    <color name="icon_container_bg">#E8F0FE</color>
    <color name="folder_container_bg">#4A7CF7</color>

    <!-- Text (light — dark text on light backgrounds) -->
    <color name="text_primary">#1A1A2E</color>
    <color name="text_secondary">#5A6A8A</color>
    <color name="text_muted">#8896B3</color>
    <color name="text_link">#4A7CF7</color>
    <color name="text_on_accent">#FFFFFF</color>

